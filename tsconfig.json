{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "target": "ES2020",
    "module": "none",
    "rootDir": "src",
    "outDir": "story",
    "strict": true,
    "declaration": false,
    "sourceMap": false,
    "noEmit": false,
    "removeComments": false,
    "esModuleInterop": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules"]
}
