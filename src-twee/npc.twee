<<set $wits += 1>>
<<goto "bai_quest_sober">>
<</link>>
<<link "「你在找关于落雁峰的资料？">>
<<run setup.setFlag('asked_bai_mountain')>>
<<set $wits += 2>>
<<goto "bai_quest_sober">>
<</link>>
<<link "（默默蹲下来帮他翻书）">>
