<<run setup.setFlag('liu_chose_duty')>>
<<set $wits += 2>>
<<goto "liu_quest_confession">>
<</link>>
<<link "「两者不矛盾。我们先找到你父亲的线索，然后以个人名义上报暗星阁的情报。">>
<<set $rel_liu += 5>>
<<run setup.setFlag('liu_chose_both')>>
<<set $wits += 3>>
